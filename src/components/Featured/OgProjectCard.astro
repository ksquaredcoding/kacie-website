---
const { project } = Astro.props;
---

<div class="col-span-1 p-6 lg:col-span-2">
  <div
    class="group h-124 cursor-pointer overflow-hidden rounded-2xl border border-foreground/10 bg-background text-foreground shadow-xl transition-all duration-500 hover:shadow-2xl md:h-144 lg:h-158 xl:h-194 2xl:h-214"
    onclick=`openModal("${project.id}")`
  >
    <div class="relative">
      <img
        src=`${project.data.images[0]}`
        alt=`${project.data.title} project image`
        class="h-60 w-full object-scale-down transition-transform duration-700 hover:scale-110 md:h-80 lg:h-100 xl:h-120 2xl:h-140"
        width="400"
        data-dynamic="alt src"
      />
    </div>
    <div class="p-6">
      <h3
        class="mb-2 font-heading text-xl text-primary transition-colors group-hover:text-secondary md:text-2xl lg:text-3xl xl:text-4xl"
        data-dynamic="text"
      >
        {project.data.title}
      </h3>
      <div class="overflow-y-scroll">
        <p
          class="font-paragraph max-h-40 overflow-y-auto pb-6 text-base leading-relaxed font-normal text-black md:text-lg lg:text-xl xl:text-2xl"
          data-dynamic="text"
        >
          {project.data.blurb}
        </p>
      </div>
    </div>
  </div>
</div>
