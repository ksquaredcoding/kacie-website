---
import NewProjectCard from "./NewProjectCard.astro";
import OgProjectCard from "./OgProjectCard.astro";

const { project } = Astro.props;
const projectIsBook = project.data.projectType == "book";
const projectIsMagazine = project.data.projectType == "magazine";
---

{
  projectIsBook || projectIsMagazine ? (
    <NewProjectCard project={project} />
  ) : (
    <OgProjectCard project={project} />
  )
}
