---
import aboutMePhoto from "../../public/images/About-Me-Photo.jpg";
---

<section class="mx-auto max-w-300 px-6 py-12">
  <div class="grid grid-cols-1 items-center lg:grid-cols-2 lg:gap-12">
    <div class="relative col-span-1 flex w-full justify-center lg:justify-end">
      <div class="relative w-max overflow-hidden rounded-2xl shadow-xl">
        <img
          src={aboutMePhoto.src}
          alt="Kacie Fromhart"
          class="h-104 w-max object-contain md:h-112 lg:h-125"
        />
      </div>
    </div>
    <div class="col-span-1 pt-6 lg:pt-0">
      <h2
        class="mb-2 font-heading text-2xl text-primary underline underline-offset-5"
      >
        About Me
      </h2>
      <p class="font-paragraph text-lg leading-relaxed text-primary/90">
        I'm a graphic designer from the west coast with a love for stories,
        crafting, and treasure hunting at local thrift stores. I'm very inspired
        by print materials and am always looking for ways to connect tactile,
        analog processes to my digital work.
      </p>
    </div>
  </div>
</section>
